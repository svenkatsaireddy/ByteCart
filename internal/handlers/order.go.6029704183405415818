package handlers

import (
	"crypto/sha256"
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"net/http"
	"strings"

	"github.com/gin-gonic/gin"
	"github.com/google/uuid"

	"oolio-backend-challenge/internal/errs"
	"oolio-backend-challenge/internal/models"
)

const headerIdempotency = "Idempotency-Key"

const (
	couponHappyHours = "HAPPYHOURS"
	couponBuyGetOne  = "BUYGETONE"
)

type orderCalculation struct {
	Items      []models.OrderItemOut
	Products   []models.Product
	CouponCode *string
	Subtotal   float64
	Discount   float64
	Total      float64
}

type validationError struct {
	status  int
	code    string
	message string
}

// PlaceOrder is POST /order.
func (h *Handler) PlaceOrder(c *gin.Context) {
	req, decodeErr := decodeOrderReq(c)
	if decodeErr != nil {
		errs.JSON(c, decodeErr.status, decodeErr.code, decodeErr.message)
		return
	}

	idempotencyKey := strings.TrimSpace(c.GetHeader(headerIdempotency))
	fingerprint := requestFingerprint(req)
	if idempotencyKey != "" && h.Idempotent != nil {
		if body, status, replay, conflict := h.Idempotent.Get(idempotencyKey, fingerprint); replay {
			c.Data(status, "application/json", body)
			return
		} else if conflict {
			errs.JSON(c, http.StatusConflict, errs.CodeConflict, "idempotency key was already used with a different request")
			return
		}
	}

	calc, validationErr := h.calculateOrder(req)
	if validationErr != nil {
		errs.JSON(c, validationErr.status, validationErr.code, validationErr.message)
		return
	}

	order := models.Order{
		ID:         uuid.NewString(),
		Items:      calc.Items,
		Products:   calc.Products,
		CouponCode: calc.CouponCode,
		Subtotal:   calc.Subtotal,
		Discount:   calc.Discount,
		Total:      calc.Total,
	}

	raw, err := json.Marshal(order)
	if err != nil {
		errs.JSON(c, http.StatusInternalServerError, errs.CodeInternal, "failed to build response")
		return
	}

	if idempotencyKey != "" && h.Idempotent != nil {
		h.Idempotent.Put(idempotencyKey, fingerprint, http.StatusOK, raw)
	}

	c.Data(http.StatusOK, "application/json", raw)
}

// ValidateCoupon previews whether a coupon is valid for the current order draft.
func (h *Handler) ValidateCoupon(c *gin.Context) {
	req, decodeErr := decodeOrderReq(c)
	if decodeErr != nil {
		errs.JSON(c, decodeErr.status, decodeErr.code, decodeErr.message)
		return
	}

	if req.CouponCode == nil || strings.TrimSpace(*req.CouponCode) == "" {
		errs.JSON(c, http.StatusUnprocessableEntity, errs.CodeValidation, "couponCode is required")
		return
	}

	calc, validationErr := h.calculateOrder(req)
	if validationErr != nil {
		errs.JSON(c, validationErr.status, validationErr.code, validationErr.message)
		return
	}

	c.JSON(http.StatusOK, models.CouponValidation{
		CouponCode: *calc.CouponCode,
		Subtotal:   calc.Subtotal,
		Discount:   calc.Discount,
		Total:      calc.Total,
		Message:    "coupon applied",
	})
}

func decodeOrderReq(c *gin.Context) (models.OrderReq, *validationError) {
	var req models.OrderReq
	dec := json.NewDecoder(c.Request.Body)
	if err := dec.Decode(&req); err != nil {
		return models.OrderReq{}, badJSON(err)
	}

	var extra json.RawMessage
	if err := dec.Decode(&extra); err != io.EOF {
		if err == nil {
			return models.OrderReq{}, &validationError{
				status:  http.StatusBadRequest,
				code:    errs.CodeBadRequest,
				message: "invalid JSON body: multiple JSON values",
			}
		}
		return models.OrderReq{}, badJSON(err)
	}

	return req, nil
}

func badJSON(err error) *validationError {
	msg := "invalid JSON body"
	var maxErr *http.MaxBytesError
	if errors.As(err, &maxErr) {
		msg = fmt.Sprintf("request body exceeds %d bytes", maxErr.Limit)
		return &validationError{
			status:  http.StatusRequestEntityTooLarge,
			code:    errs.CodeBadRequest,
			message: msg,
		}
	}
	var se *json.SyntaxError
	if errors.As(err, &se) {
		msg = fmt.Sprintf("invalid JSON at byte offset %d", se.Offset)
	}
	return &validationError{
		status:  http.StatusBadRequest,
		code:    errs.CodeBadRequest,
		message: msg,
	}
}

func requestFingerprint(req models.OrderReq) string {
	type canonicalOrderReq struct {
		CouponCode *string              `json:"couponCode,omitempty"`
		Items      []models.OrderItemIn `json:"items"`
	}

	normalized := canonicalOrderReq{
		Items: make([]models.OrderItemIn, len(req.Items)),
	}
	if req.CouponCode != nil {
		code := strings.TrimSpace(*req.CouponCode)
		if code != "" {
			normalized.CouponCode = &code
		}
	}
	for i, item := range req.Items {
		normalized.Items[i] = models.OrderItemIn{
			ProductID: strings.TrimSpace(item.ProductID),
			Quantity:  item.Quantity,
		}
	}

	raw, err := json.Marshal(normalized)
	if err != nil {
		return ""
	}
	sum := sha256.Sum256(raw)
	return fmt.Sprintf("%x", sum)
}

func (h *Handler) calculateOrder(req models.OrderReq) (orderCalculation, *validationError) {
	if len(req.Items) == 0 {
		return orderCalculation{}, &validationError{
			status:  http.StatusUnprocessableEntity,
			code:    errs.CodeValidation,
			message: "items must not be empty",
		}
	}

	var subtotal float64
	var outItems []models.OrderItemOut
	var products []models.Product
	seen := make(map[string]struct{})

	for _, line := range req.Items {
		pid := strings.TrimSpace(line.ProductID)
		if pid == "" {
			return orderCalculation{}, &validationError{
				status:  http.StatusUnprocessableEntity,
				code:    errs.CodeValidation,
				message: "productId is required for each item",
			}
		}
		if line.Quantity <= 0 {
			return orderCalculation{}, &validationError{
				status:  http.StatusUnprocessableEntity,
				code:    errs.CodeValidation,
				message: "quantity must be a positive integer",
			}
		}
		p, ok := h.Products.GetByStringID(pid)
		if !ok {
			return orderCalculation{}, &validationError{
				status:  http.StatusUnprocessableEntity,
				code:    errs.CodeValidation,
				message: "unknown product id: " + pid,
			}
		}
		subtotal += p.Price * float64(line.Quantity)
		outItems = append(outItems, models.OrderItemOut{ProductID: pid, Quantity: line.Quantity})
		if _, ok := seen[p.ID]; !ok {
			seen[p.ID] = struct{}{}
			products = append(products, p)
		}
	}

	discount := 0.0
	var couponPtr *string
	if req.CouponCode != nil {
		code := strings.TrimSpace(*req.CouponCode)
		if code != "" {
			var ok bool
			discount, ok = h.discountForCoupon(code, subtotal, req.Items)
			if !ok {
				return orderCalculation{}, &validationError{
					status:  http.StatusUnprocessableEntity,
					code:    errs.CodeValidation,
					message: "invalid or ineligible coupon code",
				}
			}
			couponPtr = &code
		}
	}

	total := subtotal - discount
	if total < 0 {
		total = 0
	}

	return orderCalculation{
		Items:      outItems,
		Products:   products,
		CouponCode: couponPtr,
		Subtotal:   round2(subtotal),
		Discount:   round2(discount),
		Total:      round2(total),
	}, nil
}

func round2(x float64) float64 {
	return float64(int64(x*100+0.5)) / 100
}

func (h *Handler) discountForCoupon(code string, subtotal float64, items []models.OrderItemIn) (float64, bool) {
	switch strings.ToUpper(code) {
	case couponHappyHours:
		return subtotal * 0.18, true
	case couponBuyGetOne:
		return h.lowestItemPrice(items), true
	default:
		if h.Promo == nil || !h.Promo.Valid(code) {
			return 0, false
		}
		return subtotal * (h.Config.PromoDiscountPercent / 100.0), true
	}
}

func (h *Handler) lowestItemPrice(items []models.OrderItemIn) float64 {
	lowest := 0.0
	for _, item := range items {
		p, ok := h.Products.GetByStringID(strings.TrimSpace(item.ProductID))
		if !ok {
			continue
		}
		if lowest == 0 || p.Price < lowest {
			lowest = p.Price
		}
	}
	return lowest
}

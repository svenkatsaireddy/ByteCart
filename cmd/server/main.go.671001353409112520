package main

import (
	"context"
	"fmt"
	"log"
	"net/http"
	"os"
	"os/signal"
	"path/filepath"
	"strings"
	"syscall"
	"time"

	"github.com/gin-gonic/gin"

	"oolio-backend-challenge/internal/config"
	"oolio-backend-challenge/internal/handlers"
	"oolio-backend-challenge/internal/idempotency"
	"oolio-backend-challenge/internal/middleware"
	"oolio-backend-challenge/internal/promo"
	"oolio-backend-challenge/internal/store"
)

func main() {
	cfg := config.Load()
	gin.SetMode(gin.ReleaseMode)
	log.Printf("products file: %s", cfg.ProductsPath)
	log.Printf("coupon files: %s", strings.Join(cfg.CouponPaths, ", "))

	ps, err := store.LoadProducts(cfg.ProductsPath)
	if err != nil {
		log.Fatalf("load products: %v", err)
	}

	pv, err := promo.NewValidatorFromGzipFiles(cfg.CouponPaths)
	if err != nil {
		if cfg.RequireCouponFiles {
			log.Fatalf("load promo corpora: %v", err)
		}
		log.Printf("warning: promo validator disabled (coupons will fail): %v", err)
		pv = nil
	} else {
		log.Printf("promo: streaming validation enabled (fast startup; first use of each new code scans the gzip files)")
	}

	auth := middleware.NewAPIAuth(cfg.APIKeys)
	h := &handlers.Handler{
		Config:     cfg,
		Products:   ps,
		Promo:      pv,
		Idempotent: idempotency.NewStore(),
	}

	r := gin.New()
	r.Use(gin.Logger(), gin.Recovery(), middleware.RequestID(), middleware.SecurityHeaders())

	r.GET("/healthz", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{
			"status": "ok",
		})
	})
	r.GET("/readyz", func(c *gin.Context) {
		ready := h.Products != nil
		promoReady := !cfg.RequireCouponFiles || h.Promo != nil
		status := http.StatusOK
		state := "ready"
		if !ready || !promoReady {
			status = http.StatusServiceUnavailable
			state = "degraded"
		}
		c.JSON(status, gin.H{
			"status": state,
			"checks": gin.H{
				"products": ready,
				"promo":    promoReady,
			},
		})
	})

	api := r.Group("/api")
	api.Use(middleware.MaxBodyBytes(cfg.RequestBodyLimit))
	api.GET("/product", h.ListProducts)
	api.GET("/product/:productId", h.GetProduct)
	api.POST("/order", auth.RequireScope("create_order"), h.PlaceOrder)
	api.POST("/coupon/validate", auth.RequireScope("create_order"), h.ValidateCoupon)
	registerFrontendRoutes(r)

	srv := &http.Server{
		Addr:         cfg.Addr,
		Handler:      r,
		ReadTimeout:  cfg.ReadTimeout,
		WriteTimeout: cfg.WriteTimeout,
		IdleTimeout:  cfg.IdleTimeout,
	}

	errCh := make(chan error, 1)
	go func() {
		log.Printf("listening on %s", cfg.Addr)
		if err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			errCh <- err
		}
		close(errCh)
	}()

	sigCtx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	select {
	case <-sigCtx.Done():
		shutdownCtx, cancel := context.WithTimeout(context.Background(), cfg.ShutdownTimeout)
		defer cancel()
		log.Printf("shutdown signal received, draining for up to %s", cfg.ShutdownTimeout)
		if err := srv.Shutdown(shutdownCtx); err != nil {
			fmt.Fprintf(os.Stderr, "shutdown: %v\n", err)
			os.Exit(1)
		}
	case err := <-errCh:
		if err != nil {
			fmt.Fprintf(os.Stderr, "server: %v\n", err)
			os.Exit(1)
		}
	}
}

func registerFrontendRoutes(r *gin.Engine) {
	dist := os.Getenv("FRONTEND_DIST")
	if dist == "" {
		dist = "frontend/dist"
	}

	indexPath := filepath.Join(dist, "index.html")
	if _, err := os.Stat(indexPath); err != nil {
		log.Printf("frontend: %s not found; serving API only", indexPath)
		return
	}

	if _, err := os.Stat(filepath.Join(dist, "assets")); err == nil {
		r.Static("/assets", filepath.Join(dist, "assets"))
	}
	r.StaticFile("/", indexPath)
	r.NoRoute(func(c *gin.Context) {
		if strings.HasPrefix(c.Request.URL.Path, "/api/") {
			middleware.JSONNotFound()(c)
			return
		}
		c.File(indexPath)
	})
}
